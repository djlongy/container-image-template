# Build artifacts
build.env
*.log

# Local image.env override. image.env.example is the tracked template
# and the fallback when no override is present. Copy and edit for
# per-dev experiments without touching the committed version:
#   cp image.env.example image.env
#   $EDITOR image.env
image.env

# CA certificates injected at build time — never committed
certs/*.crt
certs/*.pem

# Local workspace for credentials, test runners, private scratchpads.
# Source scripts from here (gitignored so hostnames/tokens stay local).
local/

# SBOM / scan outputs — produced by the pipeline, not committed
sbom*.json
sbom*.xml
grype-report.json
trivy-report.json
vulnerabilities.json

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# Python scratch (for test helpers if any)
__pycache__/
*.pyc
.venv/
