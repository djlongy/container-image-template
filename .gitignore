# Build artifacts
build.env
*.log

# image.env IS the canonical, committed config — image.env.example is
# the reference template you copy from on first checkout. Both are in
# the repo; build.sh prefers image.env, falls back to image.env.example.
# Secret values (tokens, passwords) MUST stay out of image.env — pass
# those via CI plan vars / GitLab CI variables instead.

# CA certificates and key material — injected at build time, never committed
certs/*.crt
certs/*.pem
certs/*.srl
certs/*.key
certs/*.csr
!certs/.gitkeep

# Vault / credentials — never committed
.vault-token
credentials*.env

# Agent / editor runtime state
.claude/
.playwright-mcp/

# SonarQube scanner output
.scannerwork/

# Local workspace for credentials, test runners, private scratchpads.
# Source scripts from here (gitignored so hostnames/tokens stay local).
local/

# SBOM / scan outputs — produced by the pipeline, not committed
sbom*.json
sbom*.xml
*.cdx.json
*.spdx.json
grype-report.json
trivy-report.json
vulnerabilities.json

# Auto-installed tool binaries (crane, syft) when not on PATH —
# scripts/build.sh drops them here rather than /usr/local/bin so it
# works without sudo on dev machines.
.bin/

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# Python scratch (for test helpers if any)
__pycache__/
*.pyc
.venv/
