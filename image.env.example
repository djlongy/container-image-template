# image.env.example — the ONE file that defines what this repo builds.
#
# Fork this repo per image, edit this file, commit, push. That's the
# entire workflow. The Dockerfile and scripts/build.sh stay generic —
# they just read the values below and pass them through as build-args.
#
# Resolution order (increasing precedence):
#   1. image.env.example  (tracked — fallback for fresh clones / CI)
#   2. image.env          (gitignored — local override, optional)
#   3. Shell / CI env     (always wins, for pipeline overrides)

# ═══════════════════════════════════════════════════════════════════
# IDENTITY
# ═══════════════════════════════════════════════════════════════════

# Internal semver — independent of the upstream version. Bump on each
# release of YOUR image (new remediation logic, label changes, etc.),
# separately from upstream version bumps.
VERSION="1.0.0"

# Name of the image as pushed to your registry. The final push URL is
# ${PUSH_REGISTRY}/${PUSH_PROJECT}/${IMAGE_NAME}:<tag>. If omitted,
# defaults to UPSTREAM_IMAGE. Override to rebrand (e.g. rebuilding
# upstream "nginx" as "nginx-hardened" in your registry).
# IMAGE_NAME="nginx"

# ═══════════════════════════════════════════════════════════════════
# UPSTREAM YOU'RE REBUILDING
# ═══════════════════════════════════════════════════════════════════

# Registry host + path prefix the upstream image lives at. Defaults
# to Docker Hub's library namespace. For air-gap / closed networks,
# override via the UPSTREAM_REGISTRY CI variable to point at your
# Artifactory proxy (dockerhub.artifactory.example.com/library).
UPSTREAM_REGISTRY="docker.io/library"

# Upstream image name (under UPSTREAM_REGISTRY).
UPSTREAM_IMAGE="nginx"

# Upstream tag to pin. Renovate reads the `# renovate:` hint on the
# next line and bumps this value when new upstream releases drop.
# Keep the hint's depName matching the Docker Hub repo path.
# renovate: datasource=docker depName=library/nginx
UPSTREAM_TAG="1.25.3-alpine"

# ═══════════════════════════════════════════════════════════════════
# ENRICHMENT FLAGS
# ═══════════════════════════════════════════════════════════════════

# Run CVE remediation (apk upgrade for Alpine, apt-get upgrade for
# Debian/Ubuntu, microdnf update for UBI). Set to "false" for images
# where this doesn't apply (distroless, scratch, busybox) or where
# you can't reach your apk/apt mirror. The actual upgrade command
# lives in the Dockerfile's remediate-true stage — edit that line
# for non-Alpine bases when you fork.
REMEDIATE="true"

# Inject CA certificates from the repo's certs/ directory into the
# image trust store. When the CA_CERT CI variable is set at build
# time, scripts/build.sh writes its PEM content to certs/ and flips
# this to "true" automatically.
INJECT_CERTS="false"

# USER value to restore at the end of the build. Remediation and cert
# injection run as root (required for apk / chown / etc.). This is
# the UID/username the upstream image ran as — check with:
#   docker inspect <upstream> --format='{{.Config.User}}'
# For images whose entrypoint expects to start as root and drop privs
# itself (nginx, some database images), keep "root".
ORIGINAL_USER="root"
