# image.env.example — TEMPLATE ONLY. NEVER sourced by the build.
#
# First-time setup:
#   cp image.env.example image.env  &&  $EDITOR image.env
#
# Resolution order (later wins):
#   1. image.env (committed canonical config — required)
#   2. Shell / CI env (overrides for pipeline runs)
#
# Keep secrets OUT of image.env — pass tokens / passwords as masked
# CI plan vars only. image.env is committed; shell/CI env wins so
# CI can override file values for pipeline runs.

# ═══════════════════════════════════════════════════════════════════
# UPSTREAM
# ═══════════════════════════════════════════════════════════════════
# Pushed tag = <UPSTREAM_TAG>-<gitShort>, e.g. nginx:1.25.3-alpine-a1b2c3d.
# Each push backend prepends its own host/project to this leaf.
UPSTREAM_REGISTRY="docker.io/library"
UPSTREAM_IMAGE="nginx"

# ── RENOVATE HINT (load-bearing — do not move) ──────────────────────
# The `# renovate:` line MUST sit directly above UPSTREAM_TAG and
# depName MUST match the Docker Hub repo path (drop "docker.io/").
# When forking, edit BOTH the depName below AND the UPSTREAM_TAG.
# renovate: datasource=docker depName=library/nginx
UPSTREAM_TAG="1.25.3-alpine"

# Override the pushed-image short name. Defaults to UPSTREAM_IMAGE.
# IMAGE_NAME="nginx-hardened"

# Append the git short SHA to the pushed tag (e.g. "1.25.3-alpine-a1b2c3d").
# Default true. Set false when UPSTREAM_TAG is a moving alias like "latest".
# Falsy values: false / 0 / no / off (case-insensitive). WARNING with
# false: subsequent builds OVERWRITE the same tag.
# APPEND_GIT_SHORT="true"

# OCI labels for the built image.
VENDOR="example.com"
# AUTHORS="Platform Engineering"

# ═══════════════════════════════════════════════════════════════════
# BUILD-TIME EDITS
# ═══════════════════════════════════════════════════════════════════
# CVE remediation, extra packages, config drops, HEALTHCHECK etc.
# go directly in the Dockerfile's marked editable region — NOT here.
# image.env only carries behavioural toggles; the Dockerfile is the
# customisation surface.
#
# Cert injection is automatic: drop *.crt files into certs/ (or set
# CA_CERT as an env var pointing at PEM content) and the cert sidecar
# stage in the Dockerfile picks them up. Empty certs/ = sidecar runs
# but is a no-op.

# Override the upstream image's USER (almost never needed). build.sh
# auto-detects the right value via `crane config <upstream>` and
# passes it as a build-arg — set this only if you want to force a
# different USER than what the upstream declares.
# ORIGINAL_USER="root"

# ═══════════════════════════════════════════════════════════════════
# PUSH BACKEND SELECTOR
# ═══════════════════════════════════════════════════════════════════
# Resolves to scripts/push-backends/<value>.sh. Each backend reads
# its OWN namespace and ignores the others — they never cross-derive.
# Set ONLY the section that matches REGISTRY_KIND below.
#   "harbor"      → harbor.sh       (reads HARBOR_*)
#   "artifactory" → artifactory.sh  (reads ARTIFACTORY_*)
# REGISTRY_KIND="harbor"

# ═══════════════════════════════════════════════════════════════════
# HARBOR BACKEND  (only when REGISTRY_KIND="harbor")
# ═══════════════════════════════════════════════════════════════════
# HARBOR_REGISTRY="harbor.example.com"
#
# Push URL = <HARBOR_REGISTRY>/<HARBOR_PROJECT>/<IMAGE_NAME>:<TAG>.
# HARBOR_PROJECT shapes (pick one, stick to it across forks):
#   "base-images" / "apps"        per-image-class — RBAC by base vs app
#   "dev" / "prod"                per-environment — promote = copy digest
#   "dev/cdss" / "prod/cdss"      env + team subdir — multi-team shared envs
#   "cdss/dev" / "cdss/prod"      team + env subdir — team-owned projects
#   "library"                     single shared project — tiny org
# HARBOR_PROJECT="apps/platform"
#
# HARBOR_USER="svc-cicd"
# HARBOR_PASSWORD="<harbor-cli-secret-or-robot-token>"   # mask in CI

# ═══════════════════════════════════════════════════════════════════
# ARTIFACTORY BACKEND  (only when REGISTRY_KIND="artifactory")
# ═══════════════════════════════════════════════════════════════════
# Set ARTIFACTORY_PRO=true for Pro-tier features (jf docker push +
# project-scoped build-info + jf build-scan). Default = JCR Free path.

# ── Required ────────────────────────────────────────────────────────
# ARTIFACTORY_URL="https://artifactory.example.com"   # JFrog Cloud: https://yourorg.jfrog.io
#
# ARTIFACTORY_USER must match the username encoded in your access
# token's `sub` claim, NOT the user's login email — JFrog Cloud's
# docker-login rejects email form. Find it with:
#   echo "$TOKEN" | cut -d. -f2 | base64 -d 2>/dev/null | jq -r .sub
# (take the part after the last `/`)
# ARTIFACTORY_USER="svc-cicd"
#
# Token preferred; password works if tokens aren't available. Use the
# angle-bracket placeholder shape so secret scanners don't false-positive.
# ARTIFACTORY_TOKEN="<your-jfrog-access-token>"        # mask in CI
# ARTIFACTORY_PASSWORD="<svc-cicd-password>"           # mask in CI
#
# Lowercase / digits / dashes only on JFrog Cloud.
# ARTIFACTORY_TEAM="platform"

# ── Pro tier ────────────────────────────────────────────────────────
# ARTIFACTORY_PRO="false"
# ARTIFACTORY_PROJECT="platform"               # default: ARTIFACTORY_TEAM

# ── Optional ────────────────────────────────────────────────────────
# ARTIFACTORY_ENVIRONMENT="dev"                # "prod" → prod repo suffix
# ARTIFACTORY_PUSH_HOST="docker.artifactory.example.com"  # default: host of ARTIFACTORY_URL
# ARTIFACTORY_BUILD_NAME="nginx-build"         # default: ${IMAGE_NAME}-build
# ARTIFACTORY_BUILD_NUMBER="2026.05.12-01"     # default: CI_JOB_ID / CI_PIPELINE_ID / etc.
# ARTIFACTORY_PROPERTIES="security.scan=pending;approval.status=draft"

# ── In-build Xray scans (Pro-only — opt-in, default OFF) ────────────
# Distinct from scripts/scan/xray-{vuln,sbom}.sh — those are separate
# CI stages. The BUILD_ vars below run inline in the push backend.
# ARTIFACTORY_BUILD_XRAY_PRESCAN="false"      # jf docker scan BEFORE push
# ARTIFACTORY_BUILD_XRAY_POSTSCAN="false"     # jf build-scan AFTER push
# ARTIFACTORY_XRAY_FAIL_ON_VIOLATIONS="false" # "true" → exit 1 on violation

# ── Layout templates ────────────────────────────────────────────────
# Two templates resolve the docker push URL + REST storage path.
# Available placeholders:
#   ${ARTIFACTORY_PUSH_HOST}    ${IMAGE_NAME}
#   ${ARTIFACTORY_TEAM}         ${IMAGE_TAG}
#   ${ARTIFACTORY_ENVIRONMENT}  ${ARTIFACTORY_REPO_SUFFIX}  (dev→local, prod→prod)
#
# When setting these as GitLab CI variables, use raw=true so GitLab
# doesn't expand the ${...} references at injection time.
#
# Six layout presets — uncomment ONE pair (or leave both unset for
# Layout A's defaults):
#
# ── Layout A: Per-team repos (default fallback) ─────────────────────
#   Docker push:  <host>/<team>/<image>:<tag>
#   Storage:      <team>-docker-<suffix>/<image>/<tag>/manifest.json
# ARTIFACTORY_IMAGE_REF='${ARTIFACTORY_PUSH_HOST}/${ARTIFACTORY_TEAM}/${IMAGE_NAME}:${IMAGE_TAG}'
# ARTIFACTORY_MANIFEST_PATH='${ARTIFACTORY_TEAM}-docker-${ARTIFACTORY_REPO_SUFFIX}/${IMAGE_NAME}/${IMAGE_TAG}/manifest.json'
#
# ── Layout B: Shared repo with team subfolder ───────────────────────
#   Docker push:  <host>/docker/<team>/<image>:<tag>
#   Storage:      docker/<team>/<image>/<tag>/manifest.json
# ARTIFACTORY_IMAGE_REF='${ARTIFACTORY_PUSH_HOST}/docker/${ARTIFACTORY_TEAM}/${IMAGE_NAME}:${IMAGE_TAG}'
# ARTIFACTORY_MANIFEST_PATH='docker/${ARTIFACTORY_TEAM}/${IMAGE_NAME}/${IMAGE_TAG}/manifest.json'
#
# ── Layout C: Subdomain-routed shared repo (JFrog recommended) ──────
#   Docker push:  docker.<host>/<team>/<image>:<tag>
#   Storage:      docker/<team>/<image>/<tag>/manifest.json
# ARTIFACTORY_PUSH_HOST="docker.artifactory.example.com"
# ARTIFACTORY_IMAGE_REF='${ARTIFACTORY_PUSH_HOST}/${ARTIFACTORY_TEAM}/${IMAGE_NAME}:${IMAGE_TAG}'
# ARTIFACTORY_MANIFEST_PATH='docker/${ARTIFACTORY_TEAM}/${IMAGE_NAME}/${IMAGE_TAG}/manifest.json'
#
# ── Layout D: Subdomain-per-team ────────────────────────────────────
#   Docker push:  <team>.<host>/<image>:<tag>
#   Storage:      <team>-docker-<suffix>/<image>/<tag>/manifest.json
# ARTIFACTORY_PUSH_HOST='${ARTIFACTORY_TEAM}.artifactory.example.com'
# ARTIFACTORY_IMAGE_REF='${ARTIFACTORY_PUSH_HOST}/${IMAGE_NAME}:${IMAGE_TAG}'
# ARTIFACTORY_MANIFEST_PATH='${ARTIFACTORY_TEAM}-docker-${ARTIFACTORY_REPO_SUFFIX}/${IMAGE_NAME}/${IMAGE_TAG}/manifest.json'
#
# ── Layout E: Team-dispatch subdomain (needs external nginx map) ────
#   Docker push:  docker.<host>/<team>/<image>:<tag>
#   Storage:      <team>-docker-<suffix>/<image>/<tag>/manifest.json
# ARTIFACTORY_PUSH_HOST="docker.artifactory.example.com"
# ARTIFACTORY_IMAGE_REF='${ARTIFACTORY_PUSH_HOST}/${ARTIFACTORY_TEAM}/${IMAGE_NAME}:${IMAGE_TAG}'
# ARTIFACTORY_MANIFEST_PATH='${ARTIFACTORY_TEAM}-docker-${ARTIFACTORY_REPO_SUFFIX}/${IMAGE_NAME}/${IMAGE_TAG}/manifest.json'
#
# ── Layout F: JFrog Cloud / Pro virtual repo (path-based) ───────────
#   Docker push:  <host>/<virtual>/<image>:<tag>
#   Storage:      <local>/<image>/<tag>/manifest.json
# ARTIFACTORY_PUSH_HOST="yourorg.jfrog.io"
# ARTIFACTORY_IMAGE_REF='${ARTIFACTORY_PUSH_HOST}/${ARTIFACTORY_TEAM}-docker-dev/${IMAGE_NAME}:${IMAGE_TAG}'
# ARTIFACTORY_MANIFEST_PATH='${ARTIFACTORY_TEAM}-docker-dev-local/${IMAGE_NAME}/${IMAGE_TAG}/manifest.json'

# ═══════════════════════════════════════════════════════════════════
# SCAN-SIDE ARTIFACTORY OVERRIDES
# ═══════════════════════════════════════════════════════════════════
# Use these when you push to one Artifactory (e.g. JCR Free) but scan
# via a different Pro/Cloud instance with an Xray licence. Unset =
# scan scripts use ARTIFACTORY_URL/USER/TOKEN (same instance as push).
# XRAY_ARTIFACTORY_URL="https://yourorg.jfrog.io"
# XRAY_ARTIFACTORY_USER="svc-xray"
# XRAY_ARTIFACTORY_TOKEN="<your-jfrog-access-token>"     # mask in CI

# Generate a CycloneDX SBOM via a SECOND `jf docker scan` call.
# Default ON. Set "false" when Syft / Trivy is producing the SBOM.
# XRAY_GENERATE_SBOM="true"

# Override the scan target for xray-vuln.sh / xray-sbom.sh. Default
# resolution: $1 > XRAY_SCAN_REF > IMAGE_DIGEST > IMAGE_REF > UPSTREAM_REF.
# XRAY_SCAN_REF="docker.io/library/nginx:1.25.3-alpine"

# ═══════════════════════════════════════════════════════════════════
# SEVERITY GATES (opt-in — exit 2 on violation, blocks the job)
# ═══════════════════════════════════════════════════════════════════
# Each scanner has its own var (case differs per tool). Comma-separated.
# XRAY_FAIL_ON_SEVERITY="critical,high"
# GRYPE_FAIL_ON_SEVERITY="Critical,High"
# TRIVY_FAIL_ON_SEVERITY="CRITICAL,HIGH"

# ═══════════════════════════════════════════════════════════════════
# TOOL INSTALL URLS  (closed-network / air-gap support)
# ═══════════════════════════════════════════════════════════════════
# Each scan/build script auto-installs its tool from the URL below if
# not on PATH. Defaults reach public GitHub releases — override these
# to point at your internal Artifactory mirror when air-gapped.
#
# Dockerfile's cert sidecar uses a SHELL-BEARING builder image so it
# works on shell-less / distroless / chainguard / scratch upstreams.
# Default: alpine:3.20 from Docker Hub.
#
# Air-gap: set this to a PRE-BAKED image hosted in your internal
# Artifactory that already contains:
#   - ca-certificates (with update-ca-certificates / update-ca-trust)
#   - your internal CA pre-trusted (so it can pull from Artifactory)
# Example:
#   CERT_BUILDER_IMAGE="artifactory.example.com/library/alpine-with-corp-ca:3.20"
# This avoids the chicken-and-egg of "need internal CA to install
# ca-certificates from internal Artifactory". The cert injection
# itself uses cat-append (no rebuild required), so the builder image
# only needs the bundle file present + your CA trusted at PULL time.
# CERT_BUILDER_IMAGE="docker.io/library/alpine:3.20"
#
# CRANE_URL="https://artifactory.example.com/artifactory/generic-tools/crane/v0.20.2/go-containerregistry_Linux_x86_64.tar.gz"
# SYFT_INSTALLER_URL="https://raw.githubusercontent.com/anchore/syft/main/install.sh"
# SYFT_VERSION="v1.14.0"
# GRYPE_INSTALLER_URL="https://raw.githubusercontent.com/anchore/grype/main/install.sh"
# GRYPE_VERSION="v0.82.0"
#
# ── JFrog CLI install (sudoless, REQUIRED for Artifactory backend) ──
# Set ONE of the three URLs. None = build fails with a clear error.
# All three install to ${JF_INSTALL_DIR:-$HOME/.local/bin}.
# JF_BINARY_URL="https://artifactory.example.com/artifactory/jfrog-releases-remote/jfrog-cli/v2-jf/2.103.0/jfrog-cli-linux-amd64/jf"
# JF_DEB_URL="https://artifactory.example.com/artifactory/jfrog-debs/pool/jfrog-cli-v2-jf_2.103.0_amd64.deb"
# JF_RPM_URL="https://artifactory.example.com/artifactory/jfrog-rpms/jfrog-cli-v2-jf-2.103.0.x86_64.rpm"
# JF_INSTALL_DIR="${HOME}/.local/bin"

# ═══════════════════════════════════════════════════════════════════
# SBOM SINKS (sbom-post.sh — all opt-in, no-op when unset)
# ═══════════════════════════════════════════════════════════════════
# 5 sinks ship the canonical sbom.cdx.json to whatever you configure.
# Mix and match — set as many as apply.

# Generic CycloneDX webhook (any POST endpoint).
# SBOM_WEBHOOK_URL="https://sbom-collector.example.com/api/sbom"
# SBOM_WEBHOOK_AUTH_HEADER="Authorization: Bearer <token>"   # mask in CI

# OWASP Dependency-Track (CVE correlation + notification).
# DEPENDENCY_TRACK_URL="https://dtrack.example.com"
# DEPENDENCY_TRACK_API_KEY="<dt-api-key>"        # mask in CI
# DEPENDENCY_TRACK_PROJECT="my-image"

# Artifactory generic repo, Xray-indexed (auto-scans on upload).
# Uses ARTIFACTORY_URL/USER/TOKEN above. Path:
#   <repo>/<image>/<tag>/sbom.cdx.json
# ARTIFACTORY_SBOM_REPO="sboms-local"

# Artifactory generic repo, plain archive (no Xray expectation).
# Same path shape; use alongside SBOM_REPO when you want both an
# indexed scan AND a long-term cross-team browsable archive.
# ARTIFACTORY_SBOM_ARCHIVE_REPO="<team>-generic-<env>-local"

# Splunk HTTP Event Collector (audit trail).
# SPLUNK_HEC_URL="https://splunk.example.com:8088"
# SPLUNK_HEC_TOKEN="<your-splunk-hec-uuid>"      # mask in CI
# SPLUNK_HEC_INDEX="security"                    # default: main
# SPLUNK_HEC_SOURCETYPE="jfrog:xray:scan"        # for xray-vuln events
# SPLUNK_SBOM_SOURCETYPE="cyclonedx:json"        # for SBOM events
# SPLUNK_HEC_INSECURE="false"                    # "true" → curl -k
# SPLUNK_SOURCE="pipeline"                       # appended with "-job" → "pipeline-job"

# ═══════════════════════════════════════════════════════════════════
# RUNTIME SMOKE TEST  (scripts/scan/runtime-smoke.sh)
# ═══════════════════════════════════════════════════════════════════
# Pulls the pushed digest, starts the container, verifies it boots
# without crashing. Catches the class of bug where the build succeeds
# but the cert sidecar / editable region silently broke the entrypoint.
# Wait window before checking State.Status (default: 5s)
# RUNTIME_SMOKE_SECONDS="5"
# Enforce HEALTHCHECK if the image defines one (default: true).
# RUNTIME_SMOKE_HEALTHCHECK="true"
# Max seconds to wait for "healthy" (default: 60).
# RUNTIME_HEALTH_TIMEOUT="60"
# Tail N log lines on failure (default: 50).
# RUNTIME_SMOKE_LOGS="50"
# Extra `-e KEY=VALUE` flags for docker run, space-separated.
# Useful when the image needs env (DB URL, license key) just to start.
# RUNTIME_SMOKE_ENV="MM_SQLSETTINGS_DRIVERNAME=postgres MM_SQLSETTINGS_DATASOURCE=..."

# ═══════════════════════════════════════════════════════════════════
# CANONICAL ARTIFACT FILENAMES  (overrides — almost never needed)
# ═══════════════════════════════════════════════════════════════════
# Defaults from scripts/lib/artifact-names.sh — every producer +
# consumer reads these. Override only if running multiple producers
# in one job context (otherwise they'd collide).
# SBOM_FILE="sbom.cdx.json"
# VULN_SCAN_FILE="vuln-scan.json"
# SBOM_TARGET="image"                            # "source" → syft scans dir:${REPO_ROOT}

# ═══════════════════════════════════════════════════════════════════
# GRYPE OPTIONS
# ═══════════════════════════════════════════════════════════════════
# Air-gap CVE DB mirror. Set ARTIFACTORY_GRYPE_DB_REPO to mirror
# Anchore's DB to a generic repo; grype-vuln.sh fetches from there.
# ARTIFACTORY_GRYPE_DB_REPO="grype-db-local"
# GRYPE_DB_MIRROR_SUBPATH="grype-db/v6"          # default

# ═══════════════════════════════════════════════════════════════════
# TRIVY  (DORMANT — banned for business use, scaffold only)
# ═══════════════════════════════════════════════════════════════════
# Pinned to v0.69.3 (last safe pre-compromise binary). The scripts
# refuse v0.69.4–v0.69.6 even if the installer mirror serves them.
# TRIVY_VERSION="0.69.3"
# TRIVY_INSTALLER_URL="https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh"
# TRIVY_BINARY_URL="https://artifactory.example.com/artifactory/generic-tools/trivy/0.69.3/trivy_0.69.3_Linux-64bit.tar.gz"

# ═══════════════════════════════════════════════════════════════════
# DEBUG
# ═══════════════════════════════════════════════════════════════════
# Surface verbose [debug] decision logs from every script that sources
# scripts/lib/load-image-env.sh. Off by default to keep CI logs clean.
# BUILD_DEBUG="false"
